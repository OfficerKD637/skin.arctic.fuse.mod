<contents>
    <value name="comments">Variable for search combined widget loading</value>
    <template>generator/data/parts/basic_variable.xmltemplate</template>
    <value name="variables_name">skinvariables-searchmenu-widgetloading</value>
    <value name="variables_part">
        <items menu="searchmenu" mode="widgets" item="{item_x}">
            <item>
                <value name="widget_id">$MATH[5000 + {item_x} + 1]</value>
                <condition>{item_path}!=</condition>
                <condition>{item_disabled}!=True</condition>
                <template><![CDATA[<value condition="[Container({widget_id}).IsUpdating + Integer.IsEqual(Container({widget_id}).NumItems,0)]">[True]</value>]]></template>
            </item>
        </items>
    </value>
    <value name="variables_misc"><![CDATA[<value />]]></value>
</contents>