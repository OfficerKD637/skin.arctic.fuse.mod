<contents>
    <rules name="parts_visible">
        <rule>
            <condition>{item_path}==ActivateWindow(1195)</condition>
            <value>!Skin.HasSetting(SkinUserLogin.Disabled)</value>
        </rule>
        <rule>
            <condition>True</condition>
            <value>True</value>
        </rule>
    </rules>
    <rules name="item_label">
        <rule>
            <condition>{item_path}==ActivateWindow(weather)</condition>
            <value>$INFO[Weather.Temperature,$LOCALIZE[8] • ,]</value>
        </rule>
        <rule>
            <condition>{item_path}==ActivateWindow(1161)</condition>
            <value>$INFO[Weather.Temperature,$LOCALIZE[8] $LOCALIZE[31486] • ,]</value>
        </rule>
        <rule>
            <condition>{item_path}==AlarmClock(shutdowntimer,Powerdown())</condition>
            <value>$VAR[Label_CustomShutdownTimer]</value>
        </rule>
        <rule>
            <condition>True</condition>
            <value>{item_label}</value>
        </rule>
    </rules>
    <rules name="item_icon">
        <rule>
            <condition>{item_path}==ActivateWindow(weather)</condition>
            <value>$INFO[Weather.FanartCode,resource://resource.images.weathericons.white/,.png]</value>
        </rule>
        <rule>
            <condition>{item_path}==ActivateWindow(1161)</condition>
            <value>$INFO[Weather.FanartCode,resource://resource.images.weathericons.white/,.png]</value>
        </rule>
        <rule>
            <condition>{item_path}==AlarmClock(shutdowntimer,Powerdown())</condition>
            <value>$VAR[Image_CustomShutdownTimer]</value>
        </rule>
        <rule>
            <condition>True</condition>
            <value>{item_icon}</value>
        </rule>
    </rules>
    <rules name="item_bordersize">
        <rule>
            <condition>{item_path}==ActivateWindow(weather)</condition>
            <value>21</value>
        </rule>
        <rule>
            <condition>{item_path}==ActivateWindow(1161)</condition>
            <value>21</value>
        </rule>
        <rule>
            <condition>True</condition>
            <value>16</value>
        </rule>
    </rules>
</contents>