<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <defaultcontrol always="true">9000</defaultcontrol>
    <include>DialogInfo_Onload_Wall</include>
    <controls>

        <include content="Object_Hidden_Button">
            <param name="id">7000</param>
            <onfocus condition="Control.IsVisible(61)">SetFocus(61)</onfocus>
            <onfocus condition="!Control.IsVisible(61)">SetFocus(9000)</onfocus>
        </include>
        <include>Dialog_Dim_Overlay</include>
        <control type="group">
            <include>Dimension_DialogFullMenu</include>
            <include>Animation_BounceIn_Dialog</include>
            <include content="Dialog_Background_Panel">
                <param name="dialog_size">Dimension_DialogFullMenu</param>
                <param name="topline">false</param>
                <param name="subline">false</param>
            </include>

            <!-- Content -->
            <control type="group" id="8000">
                <include>Size_Dialog_Pad</include>

                <!-- Left -->
                <control type="group">
                    
                </control>

                <control type="group">
                    <include>Size_LeftGroup_Main</include>
                    <control type="group">
                        <include>Size_Group_Head</include>
                        <include content="Dialog_Head">
                            <param name="label">$VAR[Label_Title]</param>
                        </include>
                        <include>Dialog_Head_CloseButton</include>
                        <include>Dialog_Line</include>
                    </control>
                    <control type="group">
                        <include>Size_Group_Body</include>
                        <control type="grouplist">
                            <include>Size_Group_PlotText</include>
                            <orientation>vertical</orientation>
                            <itemgap>20</itemgap>
                            <pagecontrol>61</pagecontrol>
                            <control type="label">
                                <font>font_midi_bold</font>
                                <height>40</height>
                                <textcolor>main_fg_90</textcolor>
                                <label>$LOCALIZE[20037]</label>
                            </control>
                            <control type="group">
                                <top>10</top>
                                <height>221</height>
                                <control type="grouplist">
                                    <orientation>horizontal</orientation>
                                    <itemgap>40</itemgap>
                                    <bottom>-10</bottom>
                                    <include content="Dialog_Outline_Box">
                                        <left>0</left>
                                        <height>231</height>
                                        <width>410</width>
                                        <control type="image">
                                            <aspectratio scalediffuse="false">keep</aspectratio>
                                            <texture background="true" diffuse="diffuse/landscape_w410_h231.png">$VAR[Image_PVREpgLandscapeArt]</texture>
                                        </control>
                                    </include>
                                    <control type="grouplist">
                                        <itemgap>20</itemgap>
                                        <orientation>vertical</orientation>
                                        <include content="Dialog_AddonDetails">
                                            <param name="icon">special://skin/extras/icons/list-ul.png</param>
                                            <param name="label">$INFO[ListItem.ChannelName]$INFO[ListItem.ChannelNumberLabel, (Ch.,)]</param>
                                        </include>
                                        <include content="Dialog_AddonDetails">
                                            <param name="icon">special://skin/extras/icons/calendar.png</param>
                                            <param name="label">$INFO[ListItem.StartDate]</param>
                                        </include>
                                        <include content="Dialog_AddonDetails">
                                            <param name="icon">special://skin/extras/icons/clock.png</param>
                                            <param name="label">$INFO[ListItem.StartTime]$INFO[ListItem.EndTime, - ,]</param>
                                        </include>
                                        <include content="Dialog_AddonDetails">
                                            <param name="icon">special://skin/extras/icons/tags.png</param>
                                            <param name="label">$INFO[ListItem.Genre]</param>
                                        </include>
                                    </control>
                                </control>
                            </control>
                            <control type="label">
                                <top>40</top>
                                <font>font_midi_bold</font>
                                <height>40</height>
                                <textcolor>main_fg_90</textcolor>
                                <label>$LOCALIZE[31028]</label>
                                <visible>!String.IsEmpty(ListItem.Plot)</visible>
                            </control>
                            <control type="textbox">
                                <font>font_midi_plot</font>
                                <height>auto</height>
                                <label fallback="19055">$INFO[ListItem.Plot]</label>
                                <autoscroll>false</autoscroll>
                                <visible>!String.IsEmpty(ListItem.Plot)</visible>
                            </control>
                        </control>
                        <include content="Dialog_Scrollbar_Max">
                            <param name="id">61</param>
                            <param name="inset">false</param>
                            <onright>9000</onright>
                        </include>
                    </control>
                </control>
                <!-- Right -->
                <include content="Dialog_Button_Grouplist">
                    <param name="onleft">61</param>
                    <param name="items">Items_DialogPVRInfo</param>
                </include>
            </control>
        </control>
    </controls>
</window>
