<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1116">
    <defaultcontrol always="true">22001</defaultcontrol>
    <onload condition="!String.IsEmpty(Window(Home).Property(Shortcuts.Position))">RunScript(script.skinvariables,run_executebuiltin=special://skin/shortcuts/builtins/skinvariables-refocuscustomwidgets.json,use_rules=True,attempts=5)</onload>
    <onunload>ClearProperty(Shortcuts.Position,Home)</onunload>
    <onunload>ClearProperty(Shortcuts.Category,Home)</onunload>
    <onunload>Skin.SetString(Shortcuts.RebuildDateTime,$INFO[System.Date(yyyy-mm-dd)]_$INFO[System.Time(hh:mm:ss)])</onunload>
    <controls>

        <include content="Object_Hidden_List">
            <param name="id">29303</param>
            <content>$VAR[Path_SkinVariables_Home29303FilterPath]</content>
            <visible>String.StartsWith(Window(Home).Property(Shortcuts.Category),guid-)</visible>
        </include>
        <include content="Object_Hidden_List">
            <param name="id">29313</param>
            <content>$VAR[Path_SkinVariables_Home29313FilterPath]</content>
            <visible>String.StartsWith(Container(22001).ListItem.Property(sidemenu_guid),guid-)</visible>
        </include>

        <include content="Object_Hidden_Button">
            <param name="id">29999</param>

            <onfocus condition="String.IsEmpty(Window(Home).Property(Shortcuts.EditMenu.Previous))">PreviousMenu</onfocus>
            <onfocus condition="!String.IsEmpty(Window(Home).Property(Shortcuts.EditMenu.Previous))">SetFocus(22001)</onfocus>

            <onfocus>SetProperty(Shortcuts.EditMenu,$INFO[Window(Home).Property(Shortcuts.EditMenu.Previous)],Home)</onfocus>
            <onfocus>SetProperty(Shortcuts.EditMode,$INFO[Window(Home).Property(Shortcuts.EditMode.Previous)],Home)</onfocus>
            <onfocus>SetProperty(Shortcuts.EditGUID,$INFO[Window(Home).Property(Shortcuts.EditGUID.Previous)],Home)</onfocus>
            <onfocus>SetProperty(Shortcuts.Category,$INFO[Window(Home).Property(Shortcuts.Category.Previous)],Home)</onfocus>

            <onfocus>ClearProperty(Shortcuts.EditMenu.Previous,Home)</onfocus>
            <onfocus>ClearProperty(Shortcuts.EditMode.Previous,Home)</onfocus>
            <onfocus>ClearProperty(Shortcuts.EditGUID.Previous,Home)</onfocus>
            <onfocus>ClearProperty(Shortcuts.Category.Previous,Home)</onfocus>
        </include>

        <include content="Object_Hidden_Button">
            <param name="id">25998</param>
            <onfocus>SetProperty(Shortcuts.Category,$INFO[Container(25001).ListItem.Property(guid)],Home)</onfocus>
            <onfocus>SetFocus(23062)</onfocus>
        </include>

        <include content="Object_Hidden_Button">
            <param name="id">25999</param>

            <onfocus condition="!String.IsEmpty(Container(25001).ListItem.Property(guid))">RunPlugin($INFO[Container(22001).ListItem.Property(url)]&amp;func=do_edit&amp;&amp;sidemenu_guid&amp;&amp;$INFO[Container(25001).ListItem.Property(guid)])</onfocus>
            <onfocus condition="String.IsEmpty(Container(25001).ListItem.Property(guid)) + !String.IsEmpty(Container(22001).ListItem.Property(sidemenu_guid))">RunPlugin($INFO[Container(22001).ListItem.Property(url),,&amp;func=do_toggle&amp;&amp;sidemenu_guid])</onfocus>
            <onfocus>SetFocus(23061)</onfocus>

        </include>
        
        <include>Dialog_Dim_Overlay</include>

        <control type="group">
            <include>Animation_BounceIn_Dialog</include>
            <include>Dimension_DialogFullMenu</include>
            <include content="Dialog_Background_Panel">
                <param name="dialog_size">Dimension_DialogFullMenu</param>
            </include>

                <control type="group">
                    <include>Size_Dialog_Pad</include>
                    
                    <!-- Right -->
                    <control type="group">
                        <right>0</right>
                        <width>640</width>
                        <include>Dialog_Panel</include>
                        <control type="group">
                            <include>Size_Group_Head</include>
                            <include content="Dialog_Head">
                                <param name="id">9902</param>
                                <param name="label">$LOCALIZE[33063]</param>
                            </include>
                            <include content="Dialog_ItemPage">
                                <param name="id">23000</param>
                                <param name="items_label">$LOCALIZE[33063]</param>
                            </include>
                        </control>
                        <control type="group">
                            <include>Size_Group_Body</include>
                            <control type="group">
                                <include>Size_Grouplist_Pad</include>
                                <include>Shortcuts_DialogItems</include>

                                <!-- Hub Switcher Refocus -->
                                <include content="Object_Hidden_Button">
                                    <param name="id">23089</param>
                                    <onfocus condition="String.IsEmpty(Container(22001).ListItem.Property(hub_switcher_path)) | !String.Contains(Skin.String(Navigation.Global.Hub.Switcher.WindowIDs),Container(22001).ListItem.Property(hub_switcher_path))">AlarmClock(hubswitcher_bounce,SetFocus(23099),00:00,silent)</onfocus>
                                    <onfocus condition="!String.IsEmpty(Container(22001).ListItem.Property(hub_switcher_path))">RunScript(script.skinvariables,add_skinstring_history=Navigation.Global.Hub.Switcher.WindowIDs,value=$INFO[Container(22001).ListItem.Property(hub_switcher_path)])</onfocus>
                                    <onfocus condition="!String.IsEmpty(Container(22001).ListItem.Property(hub_switcher_path)) + String.Contains(Skin.String(Navigation.Global.Hub.Switcher.WindowIDs),Container(22001).ListItem.Property(hub_switcher_path))">AlarmClock(hubswitcher_refocus,SetFocus(23094),00:02,silent)</onfocus>
                                </include>
                                <include content="Object_Hidden_Button">
                                    <param name="id">23099</param>
                                    <onfocus>SetFocus(23089)</onfocus>
                                </include>
                            </control>
                        </control>
                    </control>
                    <control type="group">
                        <top>20</top>
                        <include content="Dialog_Scrollbar">
                            <param name="id">61</param>
                            <onleft>23000</onleft>
                            <bottom>80</bottom>
                        </include>
                    </control>

                    <!-- Left -->
                    <control type="group">
                        <right>640</right>
                        <control type="group">
                            <include>Size_Group_Head</include>
                            <include content="Dialog_Head">
                                <param name="id">9901</param>
                                <param name="label">$VAR[Label_Shortcut_TopHeader]</param>
                            </include>
                            <include content="Dialog_ItemLine">
                                <param name="visible">Control.IsVisible(22001)</param>
                                <param name="label">$INFO[Container(22001).NumItems,, $LOCALIZE[31022]]$INFO[Window(Home).Property(Shortcuts.EditMenu),  •  ,]$INFO[Window(Home).Property(Shortcuts.EditMode), — ,]$INFO[Window(Home).Property(Shortcuts.EditGUID), — ,]</param>
                            </include>
                            <include>Dialog_Head_CloseButton</include>
                        </control>
                        <control type="group">
                            <height>40</height>
                            <bottom>120</bottom>
                            <include content="Dialog_ItemLine">
                                <param name="label">$VAR[Label_Shortcut_SubHeader_GroupName]$INFO[Container(22001).ListItem.Property(name), > ,]$VAR[Label_Shortcut_SubHeader_EditMode, > ,]</param>
                            </include>
                        </control>
                        <control type="group">
                            <top>20</top>
                            <include content="Dialog_Scrollbar">
                                <param name="id">62</param>
                                <onleft>22001</onleft>
                                <onright>23001</onright>
                                <bottom>80</bottom>
                            </include>
                        </control>
                        <control type="group">
                            <include>Size_Group_Body</include>
                            <control type="group">
                                <include>Size_Grouplist_Pad</include>
                                <control type="group">
                                    <bottom>40</bottom>
                                    <include>Shortcuts_CategoriesFilter</include>
                                    <include>Shortcuts_ShortcutList</include>
                                </control>
                            </control>
                        </control>
                    </control>
                </control>
        </control>
        <include>Shortcuts_FilterSelector</include>

        <include content="Furniture_Busy">
            <param name="hasspinner">true</param>
            <param name="spinspinner">true</param>
            <param name="icon">special://skin/extras/icons/kodi.png</param>
            <param name="hasbackground">Skin.HasSetting(ToastNotifications.Tabbed)</param>
            <param name="haslabel">Skin.HasSetting(ToastNotifications.Tabbed)</param>
            <param name="spinnervisible">Skin.HasSetting(ToastNotifications.Tabbed) | [!Window.IsActive(DialogVolumeBar.xml) | Player.Muted]</param>
            <param name="visible_delay">1200</param>
            <param name="windowopen_condition">False</param>
            <param name="visible">Container(22001).IsUpdating | System.HasAlarm(hubswitcher_bounce) | System.HasAlarm(hubswitcher_refocus)</param>
        </include>

    </controls>
</window>
