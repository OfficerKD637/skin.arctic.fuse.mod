<?xml version="1.0" encoding="UTF-8"?>
<window>

    <defaultcontrol always="true">120</defaultcontrol>
    <include content="Action_OSD_SuspendAutoClose">
        <param name="window">DialogSubtitles.xml</param>
    </include>
    <controls>

        <include content="Object_Hidden_List">
            <param name="id">150</param>
            <onright>120</onright>
            <onleft>120</onleft>
            <onup>120</onup>
            <ondown>120</ondown>
        </include>
        <control type="image" id="110" description="Service Logo">
            <visible>false</visible>
        </control>
        <control type="label" id="130" description="Textbox">
            <visible>false</visible>
        </control>
        <control type="label" id="140" description="Textbox">
            <visible>false</visible>
        </control>

        <include content="Dialog_Dim_Overlay">
            <param name="visible">!Window.IsVisible(DialogSlider.xml)</param>
        </include>
        <control type="group">
            <visible>!Window.IsVisible(DialogSlider.xml)</visible>
            <include>Dimension_DialogFullMenu</include>
            <include>Animation_BounceIn_Dialog</include>
            <include content="Dialog_Background_Panel">
                <param name="dialog_size">Dimension_DialogFullMenu</param>
            </include>
            <control type="group">
                <!-- Content -->
                <control type="group" id="8000">
                    <include>Size_Dialog_Pad</include>
                    <!-- Left -->
                    <control type="group">
                        <include>Size_LeftGroup_Main</include>
                        <control type="group">
                            <include>Size_Group_Head</include>
                            <include content="Dialog_Head">
                                <param name="id">100</param>
                            </include>
                            <include content="Dialog_ItemPage">
                                <param name="id">120</param>
                                <param name="items_label">$LOCALIZE[287]</param>
                            </include>
                            <include>Dialog_Head_CloseButton</include>
                        </control>
                        <control type="group">
                            <include>Size_Group_Body</include>
                            <control type="group">
                                <bottom>70</bottom>
                                <include content="List_DialogSelect">
                                    <param name="id">120</param>
                                    <param name="itemlayout_include">Layout_DialogSubtitles</param>
                                    <param name="item_height">140</param>
                                    <param name="textcolor">dialog_fg</param>
                                    <onright>61</onright>
                                    <pagecontrol>61</pagecontrol>
                                    <include>Size_Grouplist_Pad</include>
                                </include>
                                <include content="Dialog_Scrollbar_Max">
                                    <param name="id">61</param>
                                    <param name="inset">false</param>
                                    <onleft>120</onleft>
                                    <onright>9000</onright>
                                </include>
                            </control>
                            <control type="group">
                                <height>80</height>
                                <bottom>0</bottom>
                                <include content="Dialog_InfoText">
                                    <param name="include_hintlabel">false</param>
                                    <param name="centerbottom">50%</param>
                                    <param name="label">$INFO[Player.FileName]</param>
                                    <param name="label2">$INFO[Control.GetLabel(140)]$INFO[Control.GetLabel(130), - ,]</param>
                                    <param name="subline">true</param>
                                    <param name="scroll">true</param>
                                </include>
                            </control>

                        </control>
                    </control>
                    <!-- Right -->
                    <include content="Dialog_Button_Grouplist">
                        <param name="onleft">61</param>
                        <param name="items">Items_DialogSubtitles</param>
                    </include>
                </control>
            </control>
        </control>
    </controls>
</window>
