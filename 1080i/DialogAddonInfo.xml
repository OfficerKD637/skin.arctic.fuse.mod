<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <menucontrol>7000</menucontrol>
    <defaultcontrol always="true">7000</defaultcontrol>
    <onload>AlarmClock(refocus,SetFocus(7000),00:00,silent)</onload>
    <controls>
        <include content="Object_Hidden_Button">
                <param name="id">7</param>
            </include>
            <include content="Object_Hidden_Button">
                <param name="id">7000</param>
                <onfocus condition="Control.IsVisible(61)">SetFocus(61)</onfocus>
                <onfocus condition="!Control.IsVisible(61)">SetFocus(9000)</onfocus>
            </include>
            <include>Dialog_Dim_Overlay</include>
            <control type="group">
                <include>Dimension_DialogFullMenu</include>
                <include>Animation_BounceIn_Dialog</include>
                <include content="Dialog_Background_Panel">
                    <param name="dialog_size">Dimension_DialogFullMenu</param>
                    <param name="topline">false</param>
                    <param name="subline">false</param>
                </include>

                <!-- Content -->
                <control type="group" id="8000">
                    <include>Size_Dialog_Pad</include>

                    <!-- Right -->
                    <include content="Dialog_Button_Grouplist">
                        <param name="onleft">61</param>
                        <param name="items">Items_DialogAddonInfo</param>
                    </include>
                    
                    <control type="group">
                        <include>Size_LeftGroup_Main</include>
                        <control type="group">
                            <include>Size_Group_Head</include>
                            <include content="Dialog_Head">
                                <param name="label">$INFO[ListItem.Label]</param>
                            </include>
                            <include>Dialog_Head_CloseButton</include>
                            <include>Dialog_Line</include>
                        </control>
                        <control type="group">
                            <include>Size_Group_Body</include>
                            <control type="grouplist">
                                <include>Size_Group_PlotText</include>
                                <orientation>vertical</orientation>
                                <itemgap>20</itemgap>
                                <pagecontrol>61</pagecontrol>
                                <control type="label">
                                    <font>font_midi_bold</font>
                                    <height>40</height>
                                    <textcolor>main_fg_90</textcolor>
                                    <label>$LOCALIZE[20037]</label>
                                </control>
                                <control type="group">
                                    <top>10</top>
                                    <height>210</height>
                                    <include content="Dialog_Outline_Box">
                                        <left>0</left>
                                        <height>220</height>
                                        <width>220</width>
                                        <control type="image">
                                            <aspectratio scalediffuse="false">keep</aspectratio>
                                            <texture background="true" diffuse="diffuse/square_w217_h217.png">$INFO[ListItem.Icon]</texture>
                                        </control>
                                    </include>
                                    <control type="grouplist">
                                        <left>260</left>
                                        <bottom>-10</bottom>
                                        <itemgap>20</itemgap>
                                        <orientation>vertical</orientation>
                                        <include content="Dialog_AddonDetails">
                                            <param name="icon">special://skin/extras/icons/id-card.png</param>
                                            <param name="label">$INFO[ListItem.AddonCreator]</param>
                                        </include>
                                        <include content="Dialog_AddonDetails">
                                            <param name="icon">special://skin/extras/icons/tag.png</param>
                                            <param name="label">$INFO[ListItem.AddonType]</param>
                                        </include>
                                        <include content="Dialog_AddonDetails">
                                            <param name="icon">special://skin/extras/icons/code-branch.png</param>
                                            <param name="label">$INFO[ListItem.AddonVersion,v,]</param>
                                        </include>
                                        <include content="Dialog_AddonDetails">
                                            <param name="icon">special://skin/extras/icons/clock-rotate-left.png</param>
                                            <param name="label">$VAR[Label_AddonInfo_LastUpdated]</param>
                                        </include>
                                    </control>
                                </control>
                                <control type="label">
                                    <top>40</top>
                                    <font>font_midi_bold</font>
                                    <height>40</height>
                                    <textcolor>main_fg_90</textcolor>
                                    <label>$LOCALIZE[21821]</label>
                                    <visible>!String.IsEmpty(ListItem.AddonDescription)</visible>
                                </control>
                                <control type="textbox">
                                    <font>font_midi_plot</font>
                                    <height>auto</height>
                                    <label fallback="19055">$INFO[ListItem.AddonDescription]</label>
                                    <autoscroll>false</autoscroll>
                                    <visible>!String.IsEmpty(ListItem.AddonDescription)</visible>
                                </control>
                                <control type="label">
                                    <top>40</top>
                                    <font>font_midi_bold</font>
                                    <height>40</height>
                                    <textcolor>main_fg_90</textcolor>
                                    <label>$LOCALIZE[29916]</label>
                                    <visible>!String.IsEmpty(ListItem.AddonNews)</visible>
                                </control>
                                <control type="textbox">
                                    <font>font_midi_plot</font>
                                    <height>auto</height>
                                    <label fallback="19055">$INFO[ListItem.AddonNews]</label>
                                    <autoscroll>false</autoscroll>
                                    <visible>!String.IsEmpty(ListItem.AddonNews)</visible>
                                </control>
                            </control>
                            <include content="Dialog_Scrollbar_Max">
                                <param name="id">61</param>
                                <param name="inset">false</param>
                                <onright>9000</onright>
                            </include>
                        </control>
                    </control>
                </control>
            </control>
    </controls>
</window>