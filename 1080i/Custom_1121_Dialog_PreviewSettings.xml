<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1121">
    <defaultcontrol always="true">3</defaultcontrol>

    <onload condition="!String.IsEmpty(Window(1121).Property(CustomDialogPreSelect))">AlarmClock(refocus,SetFocus(3,$INFO[Window(1121).Property(CustomDialogPreSelect)],absolute),00:00,silent)</onload>
    <onunload>ClearProperty(CustomDialogPreSelect)</onunload>
    <onunload>ClearProperty(CustomDialogPreviewSelected)</onunload>
    <onunload>ClearProperty(CustomDialogPreviewWindowID)</onunload>
    <onunload>ClearProperty(resize)</onunload>
    <controls>
        <include content="DialogSelect_Viewtypes">
            <param name="header">$INFO[Window(1121).Property(CustomDialogPreviewTitle)]</param>
            <param name="include_content">Items_Preview_LayoutMode</param>
            <param name="icon">$INFO[Container(3).ListItem.Icon]</param>
            <param name="current">String.IsEqual(Window(1121).Property(CustomDialogPreviewSelected),ListItem.Label)</param>
            <param name="resize">!String.IsEmpty(Window(1121).Property(resize))</param>
        </include>

    </controls>
</window>