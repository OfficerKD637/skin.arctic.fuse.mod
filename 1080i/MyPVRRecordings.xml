<?xml version="1.0" encoding="UTF-8"?>
<window>
    <include>View_MediaWindows_ID</include>
    <defaultcontrol always="true">50</defaultcontrol>
    <menucontrol>8000</menucontrol>
    <include>Action_Blur_Onload</include>
    <include>Action_Media_Onload</include>
    <onload condition="Skin.String(TMDbHelper.EnablePVR,Detailed)">SetProperty(TMDbHelper.EnableExtendedProperties,True)</onload>
    <onload condition="!Skin.String(TMDbHelper.EnablePVR,Detailed)">ClearProperty(TMDbHelper.EnableExtendedProperties)</onload>
    <controls>
        <include>Defs_Background_Loader</include>
        <include>View_Main</include>
        <include content="Object_Hidden_List" condition="Skin.String(TMDbHelper.EnablePVR,Detailed)">
            <param name="id">3400</param>
            <content limit="1">$INFO[Window(Home).Property(TMDbHelper.ListItem.Monitor.TMDb_ID),plugin://plugin.video.themoviedb.helper/?info=details&amp;tmdb_id=,]$INFO[Window(Home).Property(TMDbHelper.ListItem.Monitor.TMDb_Type),&amp;tmdb_type=,]</content>
        </include>
    </controls>

</window>
