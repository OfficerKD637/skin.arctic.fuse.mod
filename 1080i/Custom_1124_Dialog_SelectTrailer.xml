<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1124">

    <defaultcontrol always="true">8000</defaultcontrol>
    <onload>SetProperty(TMDbHelper.ContextMenu,True)</onload>
    <onload condition="String.IsEmpty(Window(Home).Property(PlayTrailerItems)) | String.IsEqual(Window(Home).Property(PlayTrailerItems),-)">Close</onload>
    <controls>

        <control type="group">
            <include>Dimension_DialogFullMenu</include>
            
            <include content="Animation_Fade_In">
                <param name="type">WindowOpen</param>
                <param name="delay">0</param>
            </include>
            <include content="Animation_Fade_Out">
                <param name="type">WindowClose</param>
                <param name="delay">0</param>
            </include>
            
            <control type="group">
                <include>Size_Dialog_Pad</include>
                <control type="group">
                    <include>Size_LeftGroup_Main</include>
                    <control type="group">
                        <include>Size_Group_Body</include>
                        <control type="group">
                            <include>Size_Dialog_Pad</include>
                            <control type="group">
                                <control type="image">
                                    <texture diffuse="common/gradient-v.png" colordiffuse="black" border="20">common/box.png</texture>
                                </control>

                                <control type="group">
                                    <include>Animation_Right_Delay</include>
                                    <include content="List_Landscape_Row">
                                        <param name="id">8000</param>
                                        <param name="offset_x">6</param>
                                        <param name="itemlayout_include">Layout_Landscape</param>
                                        <param name="aspectratio">scale</param>
                                        <param name="include_movement">False</param>
                                        <height>divider_bottom</height>
                                        <centerbottom>160</centerbottom>
                                        <movement>2</movement>
                                        
                                        
                                        <onleft>Close</onleft>
                                        <onup>SetFocus(8000,0,absolute)</onup>
                                        <onup>Close</onup>
                                        <ondown>SetFocus(8000,0,absolute)</ondown>
                                        <ondown>Close</ondown>
                                        <onback>SetFocus(8000,0,absolute)</onback>
                                        
                                        <onclick>Close</onclick>
                                        <onclick>Dialog.Close(1123,true)</onclick>
                                        <include content="Action_PlayTrailer_OnClick">
                                            <param name="trailer">Container(8000).ListItem.FileNameAndPath</param>
                                            <param name="trailer_fallback" />
                                            <param name="title">$INFO[Container(8000).ListItem.Label]</param>
                                            <param name="items">$INFO[Window(Home).Property(PlayTrailerItems)]</param>
                                        </include>

                                        <content target="videos">$INFO[Window(Home).Property(PlayTrailerItems)]</content>
                                        <animation effect="fade" start="100" end="0" condition="Container(8000).IsUpdating">Conditional</animation>
                                    </include>
                                    <include content="Widget_Busy">
                                        <param name="label">$LOCALIZE[35232]</param>
                                        <param name="visible">Container(8000).IsUpdating</param>
                                        <param name="include">List_Landscape_Row</param>
                                        <left>5</left>
                                        <right>85</right>
                                        <height>divider_bottom</height>
                                        <centerbottom>160</centerbottom>
                                    </include>
                                </control>
                            </control>
                        </control>
                    </control>
                </control>
            </control>
        </control>
    </controls>
</window>
